import java.util.ArrayList;
import java.util.Scanner;

// Employee Class
class Employee {
    private int empId;
    private String name;
    private String designation;
    private double basicSalary;
    private double hra, da, grossSalary, deductions, netSalary;

    // Salary Constants
    private static final double HRA_RATE = 0.20;
    private static final double DA_RATE = 0.10;
    private static final double DEDUCTION_RATE = 0.08;

    // Constructor
    public Employee(int empId, String name, String designation, double basicSalary) {
        this.empId = empId;
        this.name = name;
        this.designation = designation;
        this.basicSalary = basicSalary;
        calculateSalary();
    }

    // Salary Calculation
    private void calculateSalary() {
        hra = HRA_RATE * basicSalary;
        da = DA_RATE * basicSalary;
        grossSalary = basicSalary + hra + da;
        deductions = DEDUCTION_RATE * grossSalary;
        netSalary = grossSalary - deductions;
    }

    // Getters
    public int getEmpId() {
        return empId;
    }

    public String getName() {
        return name;
    }

    // Display Basic Info
    public void displaySummary() {
        System.out.println("ID: " + empId +
                ", Name: " + name +
                ", Designation: " + designation +
                ", Net Salary: ₹" + netSalary);
    }

    // Display Full Payroll
    public void displayFullDetails() {
        System.out.println("\n--- Employee Payroll Details ---");
        System.out.println("ID: " + empId);
        System.out.println("Name: " + name);
        System.out.println("Designation: " + designation);
        System.out.println("Basic Salary: ₹" + basicSalary);
        System.out.println("HRA: ₹" + hra);
        System.out.println("DA: ₹" + da);
        System.out.println("Gross Salary: ₹" + grossSalary);
        System.out.println("Deductions: ₹" + deductions);
        System.out.println("Net Salary: ₹" + netSalary);
    }
}

// Main System Class
public class PayrollManagementSystem {

    private static ArrayList<Employee> employees = new ArrayList<>();
    private static Scanner sc = new Scanner(System.in);

    // Find Employee
    private static Employee findEmployee(int id) {
        for (Employee e : employees) {
            if (e.getEmpId() == id) {
                return e;
            }
        }
        return null;
    }

    // Add Employee
    private static void addEmployee() {
        try {
            System.out.print("Enter Employee ID: ");
            int id = sc.nextInt();
            sc.nextLine(); // fix buffer

            // Duplicate check
            if (findEmployee(id) != null) {
                System.out.println("❌ Employee ID already exists!");
                return;
            }

            System.out.print("Enter Name: ");
            String name = sc.nextLine();

            System.out.print("Enter Designation: ");
            String desig = sc.nextLine();

            System.out.print("Enter Basic Salary: ");
            double salary = sc.nextDouble();

            if (salary <= 0) {
                System.out.println("❌ Salary must be positive!");
                return;
            }

            employees.add(new Employee(id, name, desig, salary));
            System.out.println("✅ Employee Added Successfully!");

        } catch (Exception e) {
            System.out.println("❌ Invalid Input!");
            sc.nextLine(); // clear buffer
        }
    }

    // View Single Employee
    private static void viewEmployee() {
        System.out.print("Enter Employee ID: ");
        int id = sc.nextInt();

        Employee e = findEmployee(id);
        if (e != null) {
            e.displayFullDetails();
        } else {
            System.out.println("❌ Employee Not Found!");
        }
    }

    // View All Employees
    private static void viewAllEmployees() {
        if (employees.isEmpty()) {
            System.out.println("❌ No Employees Found.");
        } else {
            System.out.println("\n--- All Employees ---");
            for (Employee e : employees) {
                e.displaySummary();
            }
        }
    }

    // Delete Employee
    private static void deleteEmployee() {
        System.out.print("Enter Employee ID to delete: ");
        int id = sc.nextInt();

        Employee e = findEmployee(id);
        if (e != null) {
            employees.remove(e);
            System.out.println("✅ Employee Removed Successfully!");
        } else {
            System.out.println("❌ Employee Not Found!");
        }
    }

    // Main Menu
    public static void main(String[] args) {
        int choice;

        do {
            System.out.println("\n==============================");
            System.out.println(" Employee Payroll Management ");
            System.out.println("==============================");
            System.out.println("1. Add Employee");
            System.out.println("2. View Employee Payroll");
            System.out.println("3. View All Employees");
            System.out.println("4. Delete Employee");
            System.out.println("5. Exit");
            System.out.print("Enter your choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    addEmployee();
                    break;
                case 2:
                    viewEmployee();
                    break;
                case 3:
                    viewAllEmployees();
                    break;
                case 4:
                    deleteEmployee();
                    break;
                case 5:
                    System.out.println("👋 Exiting System...");
                    break;
                default:
                    System.out.println("❌ Invalid Choice!");
            }

        } while (choice != 5);
    }
}
